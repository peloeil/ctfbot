{
  "permissions": {
    "allow": [
      "Bash(uv run ruff check*)",
      "Bash(uv run ruff format*)",
      "Bash(uv run ty check*)",
      "Bash(uv run python -m unittest*)",
      "Bash(uv sync*)",
      "Bash(find *)",
      "Bash(wc *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)"
    ],
    "deny": [
      "Bash(uv run python src/main.py*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "f=$(grep -oPm1 '\"file_path\"\\s*:\\s*\"\\K[^\"]*'); case \"$f\" in *.py) uv run ruff format --quiet \"$f\" ;; esac 2>/dev/null || true",
            "statusMessage": "ruff format"
          }
        ]
      }
    ]
  }
}
